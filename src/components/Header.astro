---
import HeaderLink from "./HeaderLink.astro";
const baseUrl =
    !import.meta.env.BASE_URL || import.meta.env.BASE_URL === "/"
        ? ""
        : import.meta.env.BASE_URL;
---

<header>
    <nav>
        <div
            class="flex gap-2 items-center w-fit order-first lg:order-none ml-auto links"
        >
            <HeaderLink
                class="text-xs 2xl:text-lg text-base-900 hover:text-base-500 font-bold uppercase"
                href={baseUrl + "/"}
            >
                home
            </HeaderLink>
            <HeaderLink
                class="text-xs 2xl:text-lg text-base-900 hover:text-base-500 font-bold uppercase"
                href={baseUrl + "/blog"}
            >
                blog
            </HeaderLink>
            <HeaderLink
                class="text-xs 2xl:text-lg text-base-900 hover:text-base-500 font-bold uppercase"
                href={baseUrl + "/projects"}
            >
                projects
            </HeaderLink>
        </div>
    </nav>
</header>

<style>
    header {
        margin: 0;
        padding: 0 1em;
        background: white;
        box-shadow: 0 2px 8px rgba(var(--black), 0.05);
    }
    nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
    }
    .links {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        width: fit-content;
        margin-left: auto;
    }
    .links a {
        font-size: 0.75rem; /* matches text-xs */
        color: var(--base-900, #111);
        font-weight: 700;
        text-transform: uppercase;
        text-decoration: none;
        padding: 0.5rem 0.25rem;
        border-bottom: 4px solid transparent;
    }
    .links a:hover {
        color: var(--base-500, #6b7280);
    }
    .links a.active {
        border-bottom-color: var(--accent);
    }
    @media (min-width: 1536px) {
        .links a {
            font-size: 1.125rem; /* matches 2xl:text-lg */
        }
    }
</style>
