---
import PostCard from "./PostCard.astro";

/**
 * PostList.astro
 *
 * Reusable blog list component for the index page.
 *
 * Props:
 * - heading?: string (default: "Blog")
 * - posts: array of post collection items (or plain objects)
 * - limit?: number (default: 6)
 * - viewAllHref?: string (optional "View all posts" link)
 * - viewAllLabel?: string (default: "View all posts")
 *
 * Slot:
 * - default: optional slot rendered in place of the default "View all posts" link
 */

interface RawPost {
    // collection item shape:
    id?: string;
    data?: {
        title?: string;
        description?: string;
        heroImage?: any;
        pubDate?: Date | string;
    };

    // flattened shape:
    title?: string;
    description?: string;
    heroImage?: any;
    pubDate?: Date | string;

    // optional link if not a collection item:
    href?: string;
}

export interface Props {
    heading?: string;
    posts: RawPost[];
    limit?: number;
    viewAllHref?: string;
    viewAllLabel?: string;
}

const {
    heading = "Blog",
    posts = [],
    limit = 6,
    viewAllHref,
    viewAllLabel = "View all posts",
} = Astro.props as Props;

function getPostData(item: RawPost) {
    return item && (item as any).data ? (item as any).data : item;
}

function isExternal(href?: string) {
    return typeof href === "string" && /^https?:\/\//i.test(href);
}

const visiblePosts = typeof limit === "number" ? posts.slice(0, limit) : posts;

const baseUrl =
    !import.meta.env.BASE_URL || import.meta.env.BASE_URL === "/"
        ? ""
        : import.meta.env.BASE_URL;
---

<section class="max-w-[90rem] mx-auto px-8">
    <div>
        <div
            class="grid grid-cols-1 gap-y-24 md:grid-cols-3 border-b py-24 border-base-200"
        >
            <div class="lg:sticky lg:top-24 lg:z-40 self-start">
                <h2
                    class="text-sm 2xl:text-xl text-base-900 font-bold uppercase"
                >
                    {heading}
                </h2>
            </div>

            <div
                class="lg:col-span-2 grid grid-cols-1 md:grid-cols-2 gap-y-20 gap-x-8"
            >
                {
                    visiblePosts.map((post) => {
                        const p = getPostData(post) || {};
                        const id = (post as any).id;
                        const href = id
                            ? `${baseUrl}/blog/${id}`
                            : (p.href ?? undefined);
                        const rawDate = p.pubDate ?? null;
                        const pubDate = rawDate
                            ? rawDate instanceof Date
                                ? rawDate
                                : new Date(rawDate)
                            : null;

                        return (
                            <PostCard
                                title={p.title}
                                href={href}
                                image={p.heroImage}
                                imageAlt={p.title}
                                description={p.description}
                                date={pubDate}
                                variant="post"
                            />
                        );
                    })
                }
                <PostCard
                    title={viewAllLabel}
                    href={`${baseUrl + viewAllHref}`}
                    variant="post"
                />
            </div>
        </div>
    </div>
</section>
