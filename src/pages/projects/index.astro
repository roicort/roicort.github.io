---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import PageLayout from '../../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';

import { getSite } from '../../utils/consts';
import { withBase } from '../../utils/slugify';

const projects = (await getCollection('projects')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const site = await getSite();
---

<PageLayout title={`Projects · ${site.author.name}`} description="Explore case studies and recent builds.">
	<section class="content-shell py-12 space-y-10">
		<header class="space-y-2">
			<p class="text-sm uppercase tracking-[0.35em] text-muted">Projects</p>
			<h1 class="text-4xl font-semibold text-ink">Academic & Research</h1>
			<p class="text-muted max-w-3xl">
				Sharing results, learnings, and design structures that power creative and technical teams.
			</p>
		</header>
		{projects.length === 0 ? (
			<p class="text-muted">No projects published yet.</p>
		) : (
			<div class="grid grid-cols-1 gap-6 md:grid-cols-2 md:items-stretch">
				{projects.map((project) => (
					<a
								class="group block w-full h-full overflow-hidden bg-[color:var(--color-surface)] p-6 rounded-lg transition-transform duration-300 ease-in-out hover:-translate-y-1 hover:shadow-md focus-within:-translate-y-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-4 focus-visible:ring-[color:var(--color-border)] md:flex md:items-stretch md:gap-6"
						href={withBase(`/projects/${project.id}/`)}
					>
						<div class="flex flex-1 flex-col">
							<p class="text-xs font-semibold uppercase tracking-[0.35em] text-muted">Project</p>
							<h3 class="mt-2 text-xl font-semibold text-ink group-hover:text-ink">
								{project.data.title}
								<span class="inline-block ml-2 text-muted md:hidden">→</span>
							</h3>
							<time class="mt-1 text-xs uppercase tracking-[0.4em] text-muted md:hidden" datetime={project.data.pubDate.toISOString()}>
								{project.data.pubDate.toLocaleDateString('es-MX', {
									day: 'numeric',
									month: 'short',
									year: 'numeric',
								})}
							</time>
							<p class="mt-3 text-base text-muted">{project.data.description}</p>
							<div class="mt-3 hidden items-center gap-2 text-sm text-muted md:flex">
								<time datetime={project.data.pubDate.toISOString()}>
									{project.data.pubDate.toLocaleDateString('es-MX', {
										day: 'numeric',
										month: 'short',
										year: 'numeric',
									})}
								</time>
							</div>
						</div>
						<span class="ml-4 hidden md:flex items-center text-muted">
							<Icon name="tabler:arrow-right" size={20} stroke-width={1.6} class="transition-transform duration-200 group-hover:translate-x-1" />
						</span>
						<time class="sr-only" />
					</a>
				))}
			</div>
		)}
	</section>
</PageLayout>
